# Copy this file to .env and fill in your values
# .env is gitignored and will never be pushed to GitHub

# Flask
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8080

# Database
DATABASE_PATH=database/stackscope.db

# Scraper settings
SCRAPE_DELAY=2
REQUEST_TIMEOUT=10
MAX_PAGES=5

# Add any future API keys here, for example:
# SOME_API_KEY=your_key_here
